<!-- Modal de Chat -->
<div id="chat-modal" class="fixed inset-0 bg-black bg-opacity-40 flex items-center justify-center hidden z-50 p-4">
    <div class="card w-full max-w-lg h-[70vh] flex flex-col transform transition-all opacity-0 -translate-y-4">
        <div class="p-4 border-b flex justify-between items-center flex-shrink-0 gap-4">
            <h3 id="chat-modal-title" class="text-lg font-bold">Conversa</h3>
            <div class="flex items-center">
                <button id="clear-current-chat-btn" class="btn btn-ghost p-2 rounded-full w-9 h-9 text-red-500 hidden" title="Limpar histórico desta conversa"><i data-lucide="trash-2"></i></button>
                <button id="close-chat-modal-btn" class="btn btn-ghost p-2 rounded-full w-9 h-9"><i data-lucide="x"></i></button>
            </div>
        </div>
        <div id="chat-messages-container" class="flex-grow p-4 space-y-4 overflow-y-auto"></div>
        <div class="p-4 border-t flex-shrink-0">
            <div id="chat-recording-indicator" class="hidden items-center gap-2 text-sm text-red-500 mb-2">
                <i data-lucide="mic" class="w-4 h-4 animate-pulse"></i>
                <span>Gravando...</span>
                <span id="chat-recording-timer">00:00</span>
            </div>
            <form id="chat-form" class="flex items-center gap-2">
                <input type="file" id="chat-file-input" class="hidden" accept="image/*,.pdf,.doc,.docx,audio/*">
                <input type="hidden" id="chat-partner-username">
                <button type="button" id="chat-attach-file-btn" class="btn btn-secondary px-3" title="Anexar arquivo"><i data-lucide="paperclip"></i></button>
                <input type="text" id="chat-message-input" placeholder="Digite sua mensagem..." class="w-full px-3 py-2 border rounded-md bg-surface-container-high" required autocomplete="off">
                <button type="button" id="chat-record-btn" class="btn btn-secondary px-3" title="Gravar Áudio"><i data-lucide="mic"></i></button>
                <button type="submit" id="chat-send-btn" class="btn btn-primary px-4" title="Enviar Mensagem"><i data-lucide="send"></i></button>
            </form>
            <p id="chat-file-name" class="text-xs text-outline mt-1 truncate"></p>
        </div>
    </div>
</div>

<!-- Modal de Lista de Chats (Admin) -->
<div id="chat-list-modal" class="fixed inset-0 bg-black bg-opacity-40 flex items-center justify-center hidden z-50 p-4">
    <div class="card w-full max-w-md h-auto max-h-[70vh] flex flex-col transform transition-all opacity-0 -translate-y-4">
