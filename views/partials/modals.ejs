            <div class="flex justify-end items-center mt-8"><button type="submit" class="btn btn-primary"><i data-lucide="save" class="w-4 h-4"></i> Salvar Usuário</button></div>
        </form>
    </div>
</div>

<!-- Modal de Edição de Propriedade -->
