            <div class="relative">
                <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400"></i>
                <input type="text" id="chat-list-search" placeholder="Buscar proprietário..." class="w-full pl-10 pr-4 py-2 border rounded-md bg-surface-container-high text-sm">
