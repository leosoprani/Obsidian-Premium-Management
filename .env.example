# ============================================================
# Variáveis de Ambiente — Storey Luxor
# COPIE ESTE ARQUIVO para .env e preencha os valores reais
# NUNCA suba o .env para o GitHub
# ============================================================

# URL de conexão com MongoDB Atlas (produção)
# Formato: mongodb+srv://USUARIO:SENHA@cluster0.XXXXX.mongodb.net/storeyLuxorDB
MONGO_URL=mongodb://127.0.0.1:27017

# Chave secreta para assinar os tokens JWT
# Use uma string longa e aleatória em produção!
JWT_SECRET=stl_secret_key_2025_TROQUE_EM_PRODUCAO

# Porta do servidor (o Render define PORT automaticamente)
PORT=3000

# Ambiente (development | production)
NODE_ENV=development
